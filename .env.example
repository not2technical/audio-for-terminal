# Picovoice Access Key Configuration
# =====================================
#
# This file is a TEMPLATE for your .env file.
# DO NOT add your actual API key to this file!
#
# Steps to configure:
# 1. Copy this file: cp .env.example .env
# 2. Visit https://console.picovoice.ai/
# 3. Sign up for a free account (no credit card required)
# 4. Create a new access key
# 5. Copy your key and paste it below in your .env file
#
# OR use the automated setup script:
#   ./setup-access-key.sh
#
# ⚠️  SECURITY WARNING:
# - NEVER commit your .env file to version control
# - The .env file is automatically excluded by .gitignore
# - Your API key is private - treat it like a password
#
# Free tier limits:
# - Wake word detections are processed using this key
# - Speech-to-text (Whisper) runs locally and doesn't use this key
#

PICOVOICE_ACCESS_KEY=your_picovoice_access_key_here
